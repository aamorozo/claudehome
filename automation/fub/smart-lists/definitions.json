    {
      "name": "FUB Apps",
      "fubSmartListId": "REPLACE_WITH_ID",
      "filters": {
        "stage": [
          "Application",
          "Appointments",
          "No Show Appt",
          "Application-Lending Pad",
          "Pending Submission"
        ]
      },
      "reportSection": "Money List"
    },
    {
      "name": "Referrals To Convert",
      "fubSmartListId": "REPLACE_WITH_ID",
      "filters": {
        "stage": "Referrals To Convert"
      },
      "reportSection": "Money List"
    },
    {
      "name": "New Today",
      "fubSmartListId": "REPLACE_WITH_ID",
      "filters": {
        "createdToday": true
      },
      "reportSection": "New Business"
    },
    {
      "name": "Uncontacted >15min",
      "fubSmartListId": "REPLACE_WITH_ID",
      "filters": {
        "stage": "New",
